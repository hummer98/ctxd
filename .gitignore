.envrc
.team/
.worktrees/

# Claude Code project config: commit commands/, ignore local settings
.claude/settings.local.json

# Build artifacts
/ctxd
# eval scenarios で agent が `go build -o bin/ctxd` を打つことがあるため除外 (T018)
/bin/

# goreleaser build artifacts
dist/

# Eval harness (regenerated on each run)
evals/.eval-plugin/
# evals/results/ の軽量メタ (summary.md / index.{md,csv}) は commit 対象。
# 重い JSONL / meta.json は再 run で再現できるので ignore する (T014 plan §2).
evals/results/*/session-*.jsonl
evals/results/*/session-*.meta.json
evals/results/*/session-*.done
evals/results/*/session-*.settings.json

# Python bytecode (mainly from evals/summarize.py)
__pycache__/
*.pyc

# npm
node_modules/
*.tgz
# bootstrap 時の `npm install` 産物 (本 repo は npm 依存ゼロのため不要)
package-lock.json
